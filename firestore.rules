rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    

    // 화이트리스트 (회원정보) - 본인 정보만 수정 가능 (교사/관리자는 타인 정보 수정 가능, 목업은 목업만)
    match /whitelist/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        (request.auth.token.email != null && request.auth.token.email == email) || 
        email.matches('.*@mock\\.com') ||
        (request.auth.token.email != null && get(/databases/$(database)/documents/whitelist/$(request.auth.token.email)).data.role in ['teacher', 'admin'])
      );
    }

    // 클래스 관리 - 교사(생성자)만 수정/삭제 가능, 학생은 읽기만 가능
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.get('createdBy', '') == request.auth.uid || resource.data.get('createdBy', '').matches('.*@mock\\.com'));
    }

    // 폴더 - 생성자만 관리
    match /folders/{folderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.get('createdBy', '') == request.auth.uid || resource.data.get('createdBy', '').matches('.*@mock\\.com'));
    }

    // 토픽 - 생성자만 관리
    match /topics/{topicId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.get('createdBy', '') == request.auth.uid || resource.data.get('createdBy', '').matches('.*@mock\\.com'));
    }

    // 콘텐츠 - 생성자만 관리
    match /contents/{contentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.get('createdBy', '') == request.auth.uid || resource.data.get('createdBy', '').matches('.*@mock\\.com'));
    }

    // 학습 기록 (점수) - 학생 본인만 생성/수정 가능
    match /scores/{scoreId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.resource.data.get('studentId', '') == request.auth.uid || request.resource.data.get('studentId', '').matches('.*@mock\\.com'));
      allow delete: if request.auth != null && (resource.data.get('studentId', '') == request.auth.uid || resource.data.get('studentId', '').matches('.*@mock\\.com'));
    }
  }
}
